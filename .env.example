# Base de datos (Neon PostgreSQL)
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require&channel_binding=require"

# Auth.js / NextAuth
AUTH_SECRET="change-me-in-production"
# In production, set your real public URL, e.g. https://theclubhousecr.com
# In local development you can omit NEXTAUTH_URL and keep AUTH_TRUST_HOST=true
# NEXTAUTH_URL="https://your-domain.com"
AUTH_TRUST_HOST="true"

# Dev (optional): extra hosts allowed to request Next.js dev assets/HMR.
# Comma-separated hostnames/IPs, e.g. "172.16.28.177,my-laptop.local"
# NEXT_ALLOWED_DEV_ORIGINS=""

# Docker compose host port (optional). Default used in compose: 4387
DOCKER_HOST_PORT="4387"

# Upload
UPLOAD_DIR="./public/uploads"
